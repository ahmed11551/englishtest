# Скопируй этот файл как .env и подставь токен от @BotFather.

# Файл .env в репозиторий не коммитить.



BOT_TOKEN=



# Необязательно: подписи в приветствии

# BRAND_TITLE=Тест английского · Grammar Check

# BRAND_SUBTITLE=Grammar & Usage (B2) · определение уровня и темы для повторения

# LOG_LEVEL=INFO

# Путь к файлу лидов (JSON Lines). По умолчанию data/leads.jsonl рядом с проектом.

# LEADS_FILE=/var/lib/english-bot/leads.jsonl

# Если прямой доступ к Telegram режется — прокси (для socks5: pip install "python-telegram-bot[socks]")

# TELEGRAM_PROXY=http://127.0.0.1:7890

# Пропустить проверку связи перед стартом (только если понимаешь риск):

# SKIP_TELEGRAM_CHECK=1

# Публичный HTTPS URL Mini App (после деплоя папки web/ на Vercel и т.п.):
# WEBAPP_URL=https://your-project.vercel.app/
